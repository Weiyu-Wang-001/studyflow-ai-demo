# AI provider: openai, claude, or tongyi
AI_PROVIDER=openai

# OpenAI configuration (default)
OPENAI_API_KEY=
OPENAI_API_URL=https://api.openai.com/v1/chat/completions
OPENAI_MODEL=gpt-4o-mini

# Claude / Anthropic configuration
CLAUDE_API_KEY=
CLAUDE_API_URL=https://api.anthropic.com/v1/chat/completions
CLAUDE_MODEL=claude-3.5-sonic

# Tongyi configuration
TONGYI_API_KEY=
TONGYI_API_URL=https://dashscope.aliyuncs.com/compatible-mode/v1/chat/completions
TONGYI_MODEL=qwen-plus

# Generic fallback key if provider-specific key is not set
AI_API_KEY=
